{
  "appId": "com.latent-info.gui",
  "productName": "LatentInfo",
  "npmRebuild": false,
  "extraMetadata": {
    "main": "./dist/main.js"
  },
  "mac": {
    "target": ["dmg", "zip"],
    "category": "public.app-category.developer-tools",
    "electronLanguages": ["en"]
  },
  "files": [
    "dist/**/*",
    "icons/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "../frontend/dist",
      "to": "frontend",
      "filter": ["**/*"]
    }
  ],
  "afterPack": "./scripts/afterPack.cjs",
  "directories": {
    "buildResources": "build",
    "output": "release"
  }
}
