{
  "appId": "com.latent-info.gui",
  "productName": "LatentInfo",
  "npmRebuild": false,
  "extraMetadata": {
    "main": "./dist/main.js"
  },
  "mac": {
    "target": ["dmg", "zip"],
    "category": "public.app-category.developer-tools"
  },
  "files": [
    "dist/**/*"
  ],
  "extraResources": [
    {
      "from": "../backend/dist",
      "to": "backend",
      "filter": ["**/*"]
    },
    {
      "from": "../frontend/dist",
      "to": "frontend",
      "filter": ["**/*"]
    }
  ],
  "directories": {
    "buildResources": "build",
    "output": "release"
  }
}
