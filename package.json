{
  "name": "latent_info",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev:kill": "lsof -ti:5173 -ti:5174 -ti:9223 2>/dev/null | xargs kill -9 2>/dev/null; pkill -f 'electron.*latent_info' 2>/dev/null; true",
    "dev": "pnpm dev:all",
    "dev:all": "node scripts/dev-all.mjs",
    "prod:all": "echo '▶ Full GUI: production mode (built frontend + embedded backend)' && pnpm dev:kill && pnpm --filter frontend build && NODE_ENV=production LATENT_INFO_STATIC_DIR=\"$PWD/packages/frontend/dist\" pnpm --dir packages/gui exec electron --import=tsx/esm .",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "package": "bash scripts/package.sh"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electronmon": "^2.0.4",
    "turbo": "^2.9.1",
    "typescript": "5.9.3",
    "wait-on": "^9.0.4",
    "ws": "^8.19.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
